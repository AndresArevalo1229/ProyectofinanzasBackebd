{
  "name": "back_finanzas",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Backend API para ProyectoFinanzas",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:db": "RUN_DB_INTEGRATION=1 vitest run --hookTimeout=60000 tests/integration/http/v1.mysql.integration.test.ts",
    "test:watch": "vitest",
    "seed:default": "tsx scripts/seed-default-admin.ts",
    "seed:reset-admin": "tsx scripts/seed-default-admin.ts --reset --confirm YES_RESET_ADMIN",
    "cleanup:production-data": "tsx scripts/cleanup-production-data.ts",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "prisma:migrate:dev": "node scripts/run-prisma.mjs migrate dev",
    "prisma:migrate:deploy": "node scripts/run-prisma.mjs migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "argon2": "^0.44.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "^3.5.2",
    "pino": "^10.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "prisma": "^7.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.0.3"
  }
}
