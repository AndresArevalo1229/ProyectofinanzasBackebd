MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=MisFinanzas
SERVER_PORT=3100
ENCUESTA_EXCLUDED_CLIENT_IDS=1907
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
JWT_ACCESS_SECRET=replace_this_access_secret_with_32_chars_min
JWT_REFRESH_SECRET=replace_this_refresh_secret_with_32_chars_min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30
# true en desarrollo/test para facilitar pruebas manuales.
# false en producción para no exponer tokens en la API.
AUTH_EXPOSE_PASSWORD_RESET_TOKEN=true
WORKSPACE_INVITE_TTL_DAYS=7
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=1 minute
SEED_ADMIN_EMAIL=admin@misfinanzas.local
SEED_ADMIN_PASSWORD=Admin12345!
SEED_ADMIN_DISPLAY_NAME=Administrador
SEED_ADMIN_WORKSPACE_NAME=Espacio personal admin
SEED_ADMIN_BASE_CURRENCY=MXN
SEED_ADMIN_TIMEZONE=America/Mexico_City
# Solo para modo reset del seed admin.
# Debe ser YES_RESET_ADMIN para confirmar borrado y recreación.
SEED_RESET_CONFIRM=
